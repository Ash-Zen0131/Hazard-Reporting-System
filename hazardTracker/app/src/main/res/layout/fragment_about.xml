<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#6A1B9A"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_avatar_circle"
                android:text="⚠"
                android:textColor="#ffffff"
                android:textSize="28sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HazardTracker"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report. Track. Stay Safe."
                android:textSize="13sp"
                android:textColor="#ffffff"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0"
                android:textSize="11sp"
                android:textColor="#ffffff"
                android:layout_marginTop="10dp"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDarkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:textStyle="bold"
                android:text="Dark Mode" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp">

            <!-- About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT THIS APP"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:padding="18dp"
                android:layout_marginBottom="24dp"
                android:text="HazardTracker lets users report and view location-based hazards — road, environmental, and building — in real time. Reports appear as map markers, helping the community stay informed and avoid risks."
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:lineSpacingExtra="4dp"/>

            <!-- Project details -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROJECT DETAILS"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:padding="18dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ICT602 Mobile Technology Group Project"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Universiti Teknologi MARA (UiTM) Perlis"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Group 5"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Team -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVELOPMENT TEAM"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:padding="6dp"
                android:layout_marginBottom="24dp">

                <!-- Member 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgMember1"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="Profile photo of Member 1"
                        android:scaleType="centerCrop"
                        android:src="@drawable/member1"
                        app:shapeAppearanceOverlay="@style/CircularImage" />

                    <TextView
                        android:id="@+id/tvMember1Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Abdul Azim Bin Mohd Sabri"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMember1Id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Student ID: 2024545195" />

                    <TextView
                        android:id="@+id/tvMember1Programme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Programme: CS251" />

                    <TextView
                        android:id="@+id/tvMember1Task"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Task: Firebase backend, web dashboard, and hosting" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/colorBackground"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"/>

                <!-- Member 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgMember2"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="Profile photo of Member 2"
                        android:scaleType="centerCrop"
                        android:src="@drawable/member2"
                        app:shapeAppearanceOverlay="@style/CircularImage" />

                    <TextView
                        android:id="@+id/tvMember2Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Muhammad Nauffal Harith Bin Mohd Khalil"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMember2Id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Student ID: 2024959911" />

                    <TextView
                        android:id="@+id/tvMember2Programme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Programme: CS251" />

                    <TextView
                        android:id="@+id/tvMember2Task"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Task: Android map, GPS location, and current-location features." />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/colorBackground"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"/>

                <!-- Member 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgMember3"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="Profile photo of Member 3"
                        android:scaleType="centerCrop"
                        android:src="@drawable/member3"
                        app:shapeAppearanceOverlay="@style/CircularImage" />

                    <TextView
                        android:id="@+id/tvMember3Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Muhammad Amirul Farhan Bin Mazlan"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMember3Id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Student ID: 2024371107" />

                    <TextView
                        android:id="@+id/tvMember3Programme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Programme: CS251" />

                    <TextView
                        android:id="@+id/tvMember3Task"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Task: Hazard reporting form, Firestore submission, and validation." />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/colorBackground"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"/>

                <!-- Member 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgMember4"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="Profile photo of Member 4"
                        android:scaleType="centerCrop"
                        android:src="@drawable/member4"
                        app:shapeAppearanceOverlay="@style/CircularImage" />

                    <TextView
                        android:id="@+id/tvMember4Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Muhammad Irfan Izzat Bin Zolkifli"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMember4Id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Student ID: 2024540045" />

                    <TextView
                        android:id="@+id/tvMember4Programme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Programme: CS251" />

                    <TextView
                        android:id="@+id/tvMember4Task"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Task: Marker customization, testing, report preparation, and presentation." />

                </LinearLayout>

            </LinearLayout>

            <!-- GitHub -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROJECT REPOSITORY"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <TextView
                android:id="@+id/tvGithubLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:padding="18dp"
                android:layout_marginBottom="20dp"
                android:text="https://github.com/Ash-Zen0131/Hazard-Reporting-System"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:autoLink="web"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 HazardTracker. All rights reserved."
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:gravity="center"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>